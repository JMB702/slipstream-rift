# PartyKit server env. Copy to .env (gitignored) for local dev.
# In production, set the same keys on your PartyKit project:
#   npx partykit env add ACCESS_CODE <your-code>
#   npx partykit env add ELEVENLABS_AGENT_TOOL_SECRET <random-hex>
#   npx partykit env add ELEVENLABS_API_KEY <sk_...>

# 4-digit room gate. Players type this in the lobby to join. Set to whatever
# you want for your deploy. Unset = no gate (handy on a private LAN; not
# recommended in production).
ACCESS_CODE=

# Random hex string. The server constant-time compares the `secret` query
# param on every ElevenLabs webhook call against this value. Generate one
# with `openssl rand -hex 24`. Paste the same value into every agent's
# webhook tool definition in the ElevenLabs dashboard.
ELEVENLABS_AGENT_TOOL_SECRET=

# Your ElevenLabs account API key. Used by scripts/upload-knowledge-base.mjs
# (and only by scripts — the runtime game does not need it). Starts with `sk_`.
ELEVENLABS_API_KEY=
