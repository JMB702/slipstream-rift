{
  "name": "slipstream",
  "version": "0.0.0",
  "private": true,
  "description": "Slipstream — 3D multiplayer 3rd-person shooter",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "deploy:party": "pnpm --filter party deploy",
    "deploy:client": "pnpm --filter client build && echo 'Push to Git or run: vercel --prod'"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  }
}
